{
  "name": "sendicash-frontends",
  "private": true,
  "version": "1.0.0",
  "description": "SendiCash frontends monorepo — user wallet (web) and admin panel (admin).",
  "workspaces": [
    "web",
    "admin"
  ],
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace web",
    "dev:admin": "npm run dev --workspace admin",
    "build:web": "npm run build --workspace web",
    "build:admin": "npm run build --workspace admin",
    "build": "npm run build:web && npm run build:admin",
    "lint:admin": "npm run lint --workspace admin"
  }
}
