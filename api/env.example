# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=siabet
# Set to true to log TypeORM queries (off by default to avoid log rate limits e.g. on Railway)
# TYPEORM_LOGGING=true

# JWT & Security
JWT_SECRET=your-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-32-chars-minimum

# XRPL RLUSD Configuration
# Offramp (cashout): custody address where users send RLUSD
XRPL_RLUSD_PAYOUT_ADDRESS=rBYN2ookTDjJL5dViAxFUw3Yve9AkWMuoH
XRPL_WS_URL=wss://s.altnet.rippletest.net:51233

# Onramp (Buy RLUSD): mobile money number where users send UGX (e.g. 256787719618). Not an XRPL address.
PAY_IN_ADDRESS=256787719618
ONRAMP_RLUSD_SOURCE_ADDRESS=rBYN2ookTDjJL5dViAxFUw3Yve9AkWMuoH
ONRAMP_RLUSD_SOURCE_SECRET=your-xrpl-secret-key-here

# RLUSD Issuer Addresses
RLUSD_ISSUER=rN5JM3R9Y4rCNQbhHDsJAKkpHBLJzx3yXA
# RLUSD to UGX rate for offramp payout (converted amount sent to mobile money)
RLUSD_UGX_RATE=3720

# Google OAuth (for login)
GOOGLE_CLIENT_ID=your-google-client-id

# Email Configuration (choose one: SMTP or Mailgun)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourdomain.com

# OR Mailgun SMTP
# MAILGUN_SMTP_USER=your-mailgun-user
# MAILGUN_SMTP_PASSWORD=your-mailgun-password
# MAILGUN_SMTP_FROM=noreply@yourdomain.com

# SMS Configuration (Africa's Talking)
AFRICAS_TALKING_USERNAME=your-username
AFRICAS_TALKING_API_KEY=your-api-key
AFRICAS_TALKING_SHORT_CODE=your-short-code
AFRICAS_TALKING_BASE_URL=https://api.africastalking.com/version1/messaging

# Relworx Mobile Money (for offramp payouts)
RELWORX_BUSINESS_ACCOUNT=your-business-account
RELWORX_URL=https://payments.relworx.com/api/
RELWORX_API_KEY=your-relworx-api-key

# Firebase Cloud Messaging
FCM_ENDPOINT=https://fcm.googleapis.com/v1/projects/your-project/messages:send

# Exchange Rate APIs (optional, for getExchangeRate)
COINMARKETCAP_API_KEY=your-coinmarketcap-key
API_LAYER_API_KEY=your-api-layer-key

# Redis (optional, if used)
REDIS_URL=redis://localhost:6379

# Pi Network (optional, if used)
PI_API_KEY=your-pi-api-key
