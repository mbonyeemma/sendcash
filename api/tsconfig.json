{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "sourceMap": true,
        "types": ["node"],
        "noImplicitAny": false,
        "allowSyntheticDefaultImports": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
} 